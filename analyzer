import pandas as pd

def aggregate_exact_campaign_metrics(sp_df, sb_df):
    # Combine both reports
    combined_df = pd.concat([sp_df, sb_df], ignore_index=True)
    
    # Standardize headers
    column_mapping = {
        'Customer Search Term': 'Term',
        'Keyword': 'Term',
        'Campaign Name': 'Campaign',
        'Match Type': 'Match Type',
        'Spend': 'Spend',
        'Sales': 'Sales',
        'Orders': 'Orders',
        'Clicks': 'Clicks'
    }
    combined_df = combined_df.rename(columns=column_mapping)

    # Filter for EXACT match type only
    exact_df = combined_df[combined_df['Match Type'].str.upper() == 'EXACT']

    # GROUP BY: This ensures keywords are summarized PER CAMPAIGN
    summary_df = exact_df.groupby(['Campaign', 'Term']).agg({
        'Spend': 'sum',
        'Sales': 'sum',
        'Orders': 'sum',
        'Clicks': 'sum'
    }).reset_index()

    # Calculate Efficiency Metrics
    summary_df['ACOS'] = (summary_df['Spend'] / summary_df['Sales']).fillna(0)
    summary_df['ROAS'] = (summary_df['Sales'] / summary_df['Spend']).fillna(0)
    
    return summary_df.sort_values(by='Spend', ascending=False)

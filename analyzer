import pandas as pd
import numpy as np

def load_bulk_file(uploaded_file):
    """Loads all sheets and extracts Sponsored Products/Brands data."""
    all_sheets = pd.read_excel(uploaded_file, sheet_name=None)
    
    # Identify SP and SB sheets (Amazon often names them 'Sponsored Products Campaigns' etc.)
    sp_df = all_sheets.get('Sponsored Products Campaigns', pd.DataFrame())
    sb_df = all_sheets.get('Sponsored Brands Campaigns', pd.DataFrame())
    
    return sp_df, sb_df, all_sheets

def aggregate_unique_search_terms(sp_df, sb_df):
    """Combines data and aggregates metrics per Term per Campaign."""
    # Filter for rows that actually contain Search Term data
    combined = pd.concat([sp_df, sb_df], ignore_index=True)
    
    # Amazon bulk files use 'Ad Group Name' or 'Campaign Name' - adjust as needed
    # Focus only on rows with Search Term metrics
    if 'Search Term' not in combined.columns:
        return pd.DataFrame(columns=["Error: No 'Search Term' column found"])

    # List of metrics to sum
    metrics = [
        'Impressions', 'Clicks', 'Spend', 
        '7 Day Total Sales', '7 Day Total Orders'
    ]

    # Convert metrics to numeric, forcing errors to 0 (handles 'n/a' or empty strings)
    for col in metrics:
        if col in combined.columns:
            combined[col] = pd.to_numeric(combined[col], errors='coerce').fillna(0)

    # Grouping logic
    grouped = combined.groupby(['Campaign Name', 'Search Term'], as_index=False)[metrics].sum()

    # Calculate Performance Metrics
    grouped['CPC'] = (grouped['Spend'] / grouped['Clicks']).replace([np.inf, -np.inf], 0).fillna(0)
    grouped['ROAS'] = (grouped['7 Day Total Sales'] / grouped['Spend']).replace([np.inf, -np.inf], 0).fillna(0)
    
    # ACoS is Spend / Sales
    grouped['ACoS'] = (grouped['Spend'] / grouped['7 Day Total Sales']).replace([np.inf, -np.inf], 0).fillna(0)
    
    # Format for readability
    return grouped.sort_values(by='Spend', ascending=False)

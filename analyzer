import pandas as pd
import numpy as np
import re

def clean_column_names(df):
    """Removes currency symbols and suffixes like (AED), (INR), ($) from headers."""
    # Regex to remove strings like (AED), (INR), (USD), etc.
    df.columns = [re.sub(r'\s*\(\w{3}\)', '', col).strip() for col in df.columns]
    return df

def find_column(df, keywords):
    """Finds a column name that contains any of the provided keywords."""
    for col in df.columns:
        if any(key.lower() in col.lower() for key in keywords):
            return col
    return None

def standardize_dataframe(df):
    """Maps regional Amazon headers to a standard set of internal keys."""
    df = clean_column_names(df)
    
    # Mapping logic: Keywords to look for in headers
    mapping = {
        'Search Term': find_column(df, ['Customer Search Term', 'Search Term']),
        'Campaign': find_column(df, ['Campaign Name', 'Campaign']),
        'Impressions': find_column(df, ['Impressions']),
        'Clicks': find_column(df, ['Clicks']),
        'Spend': find_column(df, ['Spend']),
        'Sales': find_column(df, ['Total Sales', 'Sales']),
        'Orders': find_column(df, ['Total Orders', 'Orders'])
    }
    
    # Filter out None values
    valid_map = {v: k for k, v in mapping.items() if v is not None}
    df = df.rename(columns=valid_map)
    
    # Ensure numeric types
    numeric_cols = ['Impressions', 'Clicks', 'Spend', 'Sales', 'Orders']
    for col in numeric_cols:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors='coerce').fillna(0)
            
    return df

def aggregate_data(file_list):
    """Processes multiple files (India, UAE, etc.) and aggregates them."""
    all_dfs = []
    
    for file in file_list:
        # Handle both CSV and Excel
        if file.name.endswith('.csv'):
            df = pd.read_csv(file)
        else:
            # For Excel, we might need to check specific sheets
            excel_file = pd.ExcelWriter(file, engine='openpyxl') # placeholder logic
            # Simplification: read first sheet or specific SP/SB sheets
            df = pd.read_excel(file) 
            
        std_df = standardize_dataframe(df)
        all_dfs.append(std_df)
    
    combined = pd.concat(all_dfs, ignore_index=True)
    
    # Group by standardized names
    grouped = combined.groupby(['Campaign', 'Search Term'], as_index=False).agg({
        'Impressions': 'sum',
        'Clicks': 'sum',
        'Spend': 'sum',
        'Sales': 'sum',
        'Orders': 'sum'
    })
    
    # Recalculate metrics
    grouped['ROAS'] = (grouped['Sales'] / grouped['Spend']).replace([np.inf, -np.inf], 0).fillna(0)
    grouped['ACoS'] = (grouped['Spend'] / grouped['Sales']).replace([np.inf, -np.inf], 0).fillna(0)
    grouped['CTR'] = (grouped['Clicks'] / grouped['Impressions']).replace([np.inf, -np.inf], 0).fillna(0)
    grouped['CPC'] = (grouped['Spend'] / grouped['Clicks']).replace([np.inf, -np.inf], 0).fillna(0)

    return grouped.sort_values(by='Spend', ascending=False)

import pandas as pd
import numpy as np
import re

def clean_headers(df):
    """Removes quotes, currency suffixes, and extra spaces."""
    df.columns = [str(col).replace("'", "").replace('"', '').strip() for col in df.columns]
    df.columns = [re.sub(r'\s*\(\w+\)', '', col).strip() for col in df.columns]
    return df

def standardize_and_group(all_files_data, brand_keywords):
    combined_list = []
    
    for df in all_files_data:
        # 1. Clean the headers first
        df = clean_headers(df)
        
        # 2. Specific Column Mapping (Based on your M, N, Q requirement)
        # Column M (Index 12) -> Spend
        # Column N (Index 13) -> Sales
        # Column Q (Index 16) -> Orders
        
        mapping = {
            'Search Term': next((c for c in df.columns if 'Search Term' in c), df.columns[8]),
            'Campaign': next((c for c in df.columns if 'Campaign' in c), df.columns[3]),
            'Impressions': next((c for c in df.columns if 'Impressions' in c), df.columns[9]),
            'Clicks': next((c for c in df.columns if 'Clicks' in c), df.columns[10]),
            'Spend': df.columns[13], # Column M (Spends) - using index 13 as per standard CSV load
            'Sales': df.columns[14], # Column N (Ad Sales) - using index 14
            'Orders': df.columns[17] # Column Q (Orders) - using index 17
        }

        # Rename to standardized keys
        temp_df = df.rename(columns={v: k for k, v in mapping.items()})
        
        # Filter and Numeric Conversion
        cols = ['Campaign', 'Search Term', 'Impressions', 'Clicks', 'Spend', 'Sales', 'Orders']
        subset = temp_df[[c for c in cols if c in temp_df.columns]].copy()

        for col in ['Spend', 'Sales', 'Orders', 'Clicks', 'Impressions']:
            if col in subset.columns:
                # Remove any stray currency symbols like ₹ or AED inside cells
                subset[col] = subset[col].replace(r'[^\d.]', '', regex=True)
                subset[col] = pd.to_numeric(subset[col], errors='coerce').fillna(0)
        
        combined_list.append(subset)

    if not combined_list: return pd.DataFrame()

    full_data = pd.concat(combined_list, ignore_index=True)
    
    # Intent Tagging
    full_data['Term Type'] = full_data['Search Term'].apply(
        lambda x: "Target/ASIN" if (re.match(r'^b0', str(x).lower()) or len(str(x)) == 10) 
        else ("Brand" if any(b.lower() in str(x).lower() for b in brand_keywords) else "Generic")
    )
    
    # Final Aggregation
    grouped = full_data.groupby(['Campaign', 'Search Term', 'Term Type'], as_index=False).agg({
        'Impressions': 'sum', 'Clicks': 'sum', 'Spend': 'sum', 'Sales': 'sum', 'Orders': 'sum'
    })
    
    grouped['ROAS'] = (grouped['Sales'] / grouped['Spend']).replace([np.inf, -np.inf], 0).fillna(0)
    grouped['ACoS'] = (grouped['Spend'] / grouped['Sales']).replace([np.inf, -np.inf], 0).fillna(0)
    
    return grouped.sort_values(by='Spend', ascending=False)

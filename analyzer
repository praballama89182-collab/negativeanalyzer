import pandas as pd

def load_bulk_file(file):
    # Load EVERY tab in the Excel file into a dictionary of DataFrames
    all_sheets = pd.read_excel(file, sheet_name=None)
    
    # Identify the specific tabs needed for analysis
    sp_tab = 'SP Search Term Report'
    sb_tab = 'SB Search Term Report'
    
    # Extract only if they exist, otherwise return empty DataFrames to prevent crashes
    sp_df = all_sheets.get(sp_tab, pd.DataFrame())
    sb_df = all_sheets.get(sb_tab, pd.DataFrame())
    
    return sp_df, sb_df, all_sheets

def aggregate_data(sp_df, sb_df):
    # Combine SP and SB data
    combined_df = pd.concat([sp_df, sb_df], ignore_index=True)
    
    # Map Amazon's messy headers to clean names
    column_mapping = {
        'Customer Search Term': 'Term',
        'Keyword': 'Term',
        'Campaign Name': 'Campaign',
        'Spend': 'Spend',
        'Sales': 'Sales',
        'Orders': 'Orders',
        'Clicks': 'Clicks',
        'Impressions': 'Impressions'
    }
    combined_df = combined_df.rename(columns=column_mapping)

    # CRITICAL: Group by 'Term' ONLY to see performance across DIFFERENT campaigns
    agg_logic = {
        'Campaign': 'nunique',  # Counts how many different campaigns use this keyword
        'Impressions': 'sum',
        'Clicks': 'sum',
        'Spend': 'sum',
        'Sales': 'sum',
        'Orders': 'sum'
    }
    
    # This collapses the data from multiple campaigns into one "Global" row per keyword
    global_df = combined_df.groupby('Term').agg(agg_logic).reset_index()
    global_df = global_df.rename(columns={'Campaign': 'Campaign Count'})
    
    # Calculate performance metrics
    global_df['ACOS'] = (global_df['Spend'] / global_df['Sales']).fillna(0)
    global_df['CTR'] = (global_df['Clicks'] / global_df['Impressions']).fillna(0)
    
    return global_df

def perform_ngram_analysis(df, n):
    from collections import Counter
    ngram_data = []
    
    for _, row in df.iterrows():
        words = str(row['Term']).split()
        if len(words) >= n:
            for i in range(len(words) - n + 1):
                gram = " ".join(words[i:i+n])
                ngram_data.append({
                    'Term': gram,
                    'Spend': row['Spend'],
                    'Sales': row['Sales'],
                    'Clicks': row['Clicks'],
                    'Orders': row['Orders'],
                    'Campaign Count': row['Campaign Count']
                })
    
    ngram_df = pd.DataFrame(ngram_data)
    final_ngram = ngram_df.groupby('Term').agg({
        'Spend': 'sum',
        'Sales': 'sum',
        'Clicks': 'sum',
        'Orders': 'sum',
        'Campaign Count': 'max' # Shows the highest redundancy for this phrase
    }).reset_index()
    
    final_ngram['ACOS'] = (final_ngram['Spend'] / final_ngram['Sales']).fillna(0)
    return final_ngram.sort_values(by='Spend', ascending=False)

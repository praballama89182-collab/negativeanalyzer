import pandas as pd

def aggregate_unique_search_terms(sp_df, sb_df):
    # 1. Combine Sponsored Products and Sponsored Brands
    combined_df = pd.concat([sp_df, sb_df], ignore_index=True)
    
    # 2. Standardize column names for Amazon Bulk Files
    column_mapping = {
        'Campaign Name': 'Campaign',
        'Customer Search Term': 'Search Term',
        'Keyword': 'Search Term', # Fallback if Customer Search Term is missing
        'Spend': 'Spend',
        'Sales': 'Sales',
        'Clicks': 'Clicks',
        'Orders': 'Orders',
        'Impressions': 'Impressions'
    }
    combined_df = combined_df.rename(columns=column_mapping)

    # 3. Remove rows where Search Term or Campaign is missing
    combined_df = combined_df.dropna(subset=['Campaign', 'Search Term'])

    # 4. THE FIX: Group by Campaign AND Search Term to get CUMULATIVE values
    # This removes all repeats within the same campaign.
    aggregated_df = combined_df.groupby(['Campaign', 'Search Term']).agg({
        'Spend': 'sum',
        'Sales': 'sum',
        'Clicks': 'sum',
        'Orders': 'sum',
        'Impressions': 'sum'
    }).reset_index()

    # 5. Calculate efficiency metrics for the summarized rows
    aggregated_df['ACOS'] = (aggregated_df['Spend'] / aggregated_df['Sales']).fillna(0)
    aggregated_df['ROAS'] = (aggregated_df['Sales'] / aggregated_df['Spend']).fillna(0)
    
    # Sort by Spend so you see the biggest "Bleeders" or "Winners" first
    return aggregated_df.sort_values(by='Spend', ascending=False)
